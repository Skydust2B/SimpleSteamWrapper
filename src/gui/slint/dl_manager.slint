import { ComboBox, CheckBox, VerticalBox, HorizontalBox, SpinBox, Button, ScrollView, ListView, LineEdit, ProgressIndicator } from "std-widgets.slint";

// TODO: If auto-update on, check corresponding update on startup and add a 'last-update' to not spam the check
// TODO: On DLManager open, fetch corresponding GEProton and proton-cachyos versions
// TODO: Versions that are already installed in steam need to simply be "Installed"
export component DlManagerGUI inherits Window {
    width: 400px;
    height: 500px;
    title: "Simple Steam Wrapper - Download Manager";

    in property <[string]> dl_compat_tools;
    callback fetch_release(string);

    in-out property <[{ parent: string, name: string, already_downloaded: bool, auto_update: bool }]> releases: [];
    in property <{ is_downloading: bool, download_name: string, percent: int }> download_state: {
        is_downloading: false,
        percent: 0
    };
    callback install_compat_tool(string);
    callback delete_compat_tool(string);

    VerticalBox {
        HorizontalBox {
            selected_list := ComboBox {
                model: dl_compat_tools;
                selected(current-value) => { fetch_release(selected_list.current-value); }
            }
            Button {
                text: "🗘";
                clicked => { fetch_release(selected_list.current-value); }
            }
        }
        ScrollView {
            VerticalBox {
                alignment: LayoutAlignment.start;
                for row[idx] in releases: Rectangle {
                    border-color: darkgrey;
                    border-width: 1px;
                    border-radius: 3px;
                    VerticalBox {
                        alignment: LayoutAlignment.start;
                        HorizontalLayout {
                            padding: 0;
                            Text {
                                vertical-alignment: center;
                                text: row.name;
                            }
                            VerticalLayout {
                                horizontal-stretch: 0;
                                spacing: 5px;
                                HorizontalLayout {
                                    horizontal-stretch: 0;
                                    spacing: 5px;
                                    if row.already_downloaded: Button {
                                        max-width: self.preferred-width;
                                        text: "🗑";
                                        clicked => { delete_compat_tool(row.name) }
                                    }
                                    Button {
                                        max-width: self.preferred-width;
                                        text: "Install";
                                        clicked => { install_compat_tool(row.name) }
                                        enabled: (!download_state.is_downloading && !row.already_downloaded);
                                    }
                                }
                                if row.auto_update: CheckBox {
                                    horizontal-stretch: 0;
                                    text: "Auto-update";
                                }
                            }
                        }
                        if (download_state.is_downloading && row.name == download_state.download_name): HorizontalBox {
                           alignment: stretch;

                           VerticalLayout {
                               alignment: center;
                               ProgressIndicator {
                                   height: 2px;
                                   progress: download_state.percent/100;
                               }
                           }

                           Text {
                               text: download_state.percent + "%";
                           }
                       }
                    }
                }
            }
        }
    }
}
