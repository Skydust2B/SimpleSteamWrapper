import { ComboBox, CheckBox, VerticalBox, HorizontalBox, SpinBox, Button, ScrollView, ListView, LineEdit } from "std-widgets.slint";
import { EnvVar, EnvVarsSettings } from "../globals/env_vars_settings.slint";

export component EnvVarsEditor {
    Rectangle {
         border-width: 1px;
         border-radius: 10px;
         border-color: darkgrey;
         VerticalBox {
            if (EnvVarsSettings.env_vars.length > 0):
            ListView {
                min-height: Math.min(EnvVarsSettings.env_vars.length * 50, 120) * 1px;
                for row[idx] in EnvVarsSettings.env_vars: HorizontalBox {
                    LineEdit { text: row.key; edited => { row.key = self.text; } }
                    LineEdit { text: row.value; edited => { row.value = self.text } }
                    Button {
                        text: "−";
                        clicked => { EnvVarsSettings.remove_env_var(idx); }
                    }
                }
            }
            Button {
                text: "+ Add Env Var";
                clicked => { EnvVarsSettings.add_env_var(); }
            }
        }
    }
}
